// conf/desktop.config
// Configuration for local desktop/laptop execution

process {
    executor = 'local'
    maxForks = 2          // Limit parallelism on desktop
    maxRetries = 1        // Fewer retries on desktop
    
    cpus = { task.attempt == 1 ? 2 : 4 }
    memory = { task.attempt == 1 ? 8.GB : 16.GB }
    time = { task.attempt == 1 ? 6.h : 12.h }
    
    // GPU configuration for desktop (single GPU)
    withLabel: 'gpu_.*' {
        cpus = 2
        memory = 12.GB
        time = 8.h
        containerOptions = '--nv --gpus=0'
        queue = null
        clusterOptions = null
    }
}

// Parameters specific to desktop
params {
    // Desktop-friendly defaults
    max_parallel_batches = 1          // Process batches sequentially
    cellranger_localcores = 4         // Reduce from default 16
    cellranger_localmem = 16          // Reduce from default 64
    
    // Reference paths (adjust for your desktop)
    ref_dir = "/home/Apps/genomes/cellranger"
    
    // GPU strategy for desktop - try auto-detection first
    gpu_strategy = "auto"
    gpu_devices_available = [0]
    
    // Disable some GPU-intensive features if needed
    harmony_gpu = true        // Can set to false if GPU memory insufficient
    
    // Local cache for containers
    singularity_cache_dir = "${System.getProperty('user.home')}/.singularity/cache"
}

// Disable HPC-specific options
singularity {
    envWhitelist = 'PATH,LD_LIBRARY_PATH,CUDA_HOME,CUDA_VISIBLE_DEVICES'
}
