// conf/hpc.config
// Base configuration for HPC cluster execution (SLURM/SGE)

process {
    // SLURM scheduling
    executor = 'slurm'
    queue = 'compute'
    clusterOptions = '--account=mylab --qos=standard'
    
    // Track job submission
    submitRateLimit = '5sec'
    queueStatInterval = '1 min'
    pollInterval = '30sec'
    
    // Retry configuration
    maxRetries = 3
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    
    // CPU job defaults
    cpus = { task.attempt == 1 ? 8 : 16 }
    memory = { task.attempt == 1 ? 32.GB : 64.GB }
    time = { task.attempt == 1 ? 12.h : 24.h }
    
    // GPU job configuration
    withLabel: 'gpu_.*' {
        queue = 'gpu'
        clusterOptions = '--gres=gpu:1 --mem-per-cpu=4000M'
        cpus = 8
        memory = 32.GB
        time = 12.h
    }
}

// Parameters specific to HPC
params {
    // HPC-friendly defaults
    max_parallel_batches = 8          // Parallel batch processing
    cellranger_localcores = 16
    cellranger_localmem = 64
    
    // Reference paths (HPC typical location)
    ref_dir = "/home/Apps/genomes/cellranger"
    
    // GPU strategy
    gpu_strategy = "auto"
    gpu_devices_available = [0, 1, 2, 3]  // Typical HPC has multiple GPUs
    
    // Shared storage
    singularity_cache_dir = "/mnt/shared/singularity/cache"
}

// Shared storage mount points
singularity {
    autoMounts = true
    cacheDir = params.singularity_cache_dir
    runOptions = '--bind /mnt/shared:/mnt/shared --bind /scratch:/scratch'
}
