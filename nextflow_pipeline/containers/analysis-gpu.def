Bootstrap: docker
From: nvcr.io/nvidia/rapids:25.12-cuda12.0-runtime-ubuntu22.04

%labels
    Author "MAPseq Team"
    Version "1.0.0"
    Description "GPU-accelerated analysis for single-cell genomics"

%help
    GPU-accelerated single-cell analysis container
    
    Includes:
      • RAPIDS 25.12 (rapids-singlecell, cuML, CuPy)
      • Scanpy 1.10.0
      • harmonypy (PyTorch GPU backend)
      • scirpy (V(D)J analysis)
      • CUDA 12.0 runtime
    
    Usage:
      singularity exec --nv container.sif python3 analysis_script.py

%environment
    export CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES}
    export LD_LIBRARY_PATH=/usr/local/cuda-12.0/lib64:$LD_LIBRARY_PATH
    export PATH=/usr/local/cuda-12.0/bin:$PATH
    export PYTHONUNBUFFERED=1
    export RAPIDS_NATIVE_CUDA_ENABLED=1
    export MKL_THREADING_LAYER=GNU

%post
    set -e
    
    echo "Building GPU-accelerated analysis container..."
    
    # ==========================================
    # Update system
    # ==========================================
    apt-get update
    apt-get upgrade -y
    apt-get install -y \
        build-essential \
        curl \
        wget \
        git \
        htop \
        vim \
        less \
        nano \
        ca-certificates
    
    # ==========================================
    # Python environment setup
    # ==========================================
    echo "Setting up Python environment..."
    
    pip install --upgrade pip setuptools wheel
    
    # ==========================================
    # Core analysis stack
    # ==========================================
    echo "Installing Scanpy and dependencies..."
    
    pip install --no-cache-dir \
        'scanpy==1.10.0' \
        'anndata>=0.10.0' \
        'pandas>=2.0' \
        'numpy>=1.24' \
        'scipy>=1.10' \
        'scikit-learn>=1.2' \
        'matplotlib>=3.5' \
        'seaborn>=0.12' \
        'networkx>=3.0' \
        'leidenalg>=0.10' \
        'numba>=0.56' \
        'pynndescent>=0.5' \
        'umap-learn>=0.5'
    
    # ==========================================
    # GPU acceleration (rapids-singlecell)
    # ==========================================
    echo "Installing GPU acceleration libraries..."
    
    pip install --no-cache-dir \
        'rapids-singlecell>=0.12.0' \
        'cuml-cu12>=25.12' \
        'cugraph-service-client' \
        'cugraph-cu12'
    
    # PyTorch for Harmony GPU backend
    pip install --no-cache-dir \
        'torch>=2.0' \
        'torchvision' \
        'torchaudio'
    
    # ==========================================
    # Batch integration (Harmony with GPU)
    # ==========================================
    echo "Installing Harmony (PyTorch backend)..."
    
    pip install --no-cache-dir \
        'harmonypy>=0.2.0'
    
    # ==========================================
    # V(D)J analysis (scirpy)
    # ==========================================
    echo "Installing V(D)J analysis tools..."
    
    pip install --no-cache-dir \
        'scirpy>=0.13.0' \
        'immuneml>=5.0' \
        'dandelion>=0.3'
    
    # ==========================================
    # Ambient RNA removal (optional)
    # ==========================================
    echo "Installing optional ambient RNA removal..."
    
    pip install --no-cache-dir \
        'SoupX>=1.0' \
        'cellbender>=0.3.2'
    
    # Note: CellBender has complex PyTorch dependencies
    # Build may fail; this is optional and can be skipped
    
    # ==========================================
    # QC and analysis utilities
    # ==========================================
    echo "Installing analysis utilities..."
    
    pip install --no-cache-dir \
        'doubletdetection>=2.5' \
        'solo>=1.0' \
        'scDblFinder-py>=0.1' \
        'decoupler>=1.4' \
        'cell2cell>=0.4' \
        'pertpy>=0.2'
    
    # ==========================================
    # Data I/O and utilities
    # ==========================================
    echo "Installing I/O utilities..."
    
    pip install --no-cache-dir \
        'h5py>=3.7' \
        'tables>=3.8' \
        'zarr>=2.13' \
        'pyyaml>=6.0' \
        'click>=8.1' \
        'tqdm>=4.65' \
        'rich>=13.3'
    
    # ==========================================
    # Optional: R environment for cross-language support
    # ==========================================
    echo "Installing R and rpy2 bridge..."
    
    apt-key adv --keyserver keyserver.ubuntu.com --recv-keys E298A3A825C0D65DFD57CBB651716619E084DAB9
    echo "deb https://cloud.r-project.org/bin/linux/ubuntu jammy-cran40/" | tee /etc/apt/sources.list.d/r-project.list
    apt-get update
    apt-get install -y r-base r-base-dev
    
    # rpy2 for R integration
    pip install --no-cache-dir 'rpy2>=3.14'
    
    # Minimal R packages
    R --vanilla --slave << 'EOF'
options(repos = c(CRAN = "https://cloud.r-project.org"))
packages <- c("devtools", "Matrix", "igraph", "ggplot2")
for (pkg in packages) {
    tryCatch(install.packages(pkg, quiet = TRUE), error = function(e) {
        message(paste("Info: Could not install", pkg))
    })
}
EOF
    
    # ==========================================
    # Verification and testing
    # ==========================================
    echo ""
    echo "========================================="
    echo "Verifying GPU acceleration setup..."
    echo "========================================="
    echo ""
    
    # Python packages
    python3 << 'VERIFY'
import sys
packages = {
    'scanpy': 'Scanpy',
    'anndata': 'AnnData',
    'rapids_singlecell': 'rapids-singlecell',
    'cuml': 'cuML',
    'harmonypy': 'Harmony',
    'scirpy': 'scirpy',
    'torch': 'PyTorch'
}

print("Python Packages:")
for module, name in packages.items():
    try:
        mod = __import__(module)
        version = getattr(mod, '__version__', 'unknown')
        print(f"  ✓ {name:25} {version}")
    except ImportError as e:
        print(f"  ✗ {name:25} NOT INSTALLED")

# GPU verification
print("\nGPU Verification:")
try:
    import torch
    print(f"  ✓ PyTorch CUDA available: {torch.cuda.is_available()}")
    if torch.cuda.is_available():
        print(f"    GPU: {torch.cuda.get_device_name(0)}")
        print(f"    CUDA: {torch.version.cuda}")
        print(f"    cuDNN: {torch.backends.cudnn.version()}")
except Exception as e:
    print(f"  ✗ GPU detection failed: {e}")

try:
    import cuml
    print("  ✓ cuML GPU backend available")
except:
    print("  ✗ cuML GPU backend not available")

try:
    import rapids_singlecell as rsc
    print("  ✓ rapids-singlecell GPU wrapper available")
except:
    print("  ✗ rapids-singlecell not available")

print("")
VERIFY
    
    # ==========================================
    # Cleanup
    # ==========================================
    apt-get clean
    rm -rf /var/lib/apt/lists/*
    pip cache purge
    
    echo "✓ GPU analysis container build complete"

%runscript
    exec python3 "$@"

%startscript
    exec python3 "$@"
