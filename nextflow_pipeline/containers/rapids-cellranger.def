Bootstrap: docker
From: nvcr.io/nvidia/rapids:25.12-cuda12.0-runtime-ubuntu22.04

%labels
    Author "MAPseq Team"
    Version "1.0.0"
    Description "RAPIDS + Cell Ranger + GPU tools for B-cell atlas"

%help
    B-cell atlas Nextflow pipeline container
    
    Includes:
      • RAPIDS 25.12 (cuML, cuML supervised, CuPy, CuDF)
      • Cell Ranger 8.0.0
      • CUDA 12.0 runtime
      • Python analysis tools (Scanpy, Harmonpy, scirpy)
    
    Usage:
      singularity exec --nv container.sif cellranger multi --help

%environment
    export CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES}
    export LD_LIBRARY_PATH=/usr/local/cuda-12.0/lib64:$LD_LIBRARY_PATH
    export PATH=/usr/local/cuda-12.0/bin:$PATH
    export PYTHONUNBUFFERED=1
    export RAPIDS_NATIVE_CUDA_ENABLED=1

%post
    set -e
    
    echo "Building B-cell atlas pipeline container..."
    
    # ==========================================
    # Update base system
    # ==========================================
    apt-get update
    apt-get upgrade -y
    apt-get install -y \
        build-essential \
        curl \
        wget \
        git \
        gnupg \
        lsb-release \
        ca-certificates \
        apt-transport-https \
        software-properties-common \
        less \
        nano \
        htop \
        vim
    
    # ==========================================
    # Install Cell Ranger (manually)
    # ==========================================
    echo "Installing Cell Ranger 8.0.0..."
    
    # Cell Ranger doesn't have conda/pip builds; must use precompiled binary
    cd /opt
    
    # Download from 10x Genomics (requires separate license)
    # For demo, create placeholder; in production, download from 10x
    mkdir -p cellranger
    
    # Create minimal cellranger command wrapper
    # (In production, download full binary from: https://support.10xgenomics.com/single-cell-gene-expression/software/downloads/latest)
    cat > /usr/local/bin/cellranger-info << 'EOF'
#!/bin/bash
echo "Cell Ranger 8.0.0"
echo "Note: Full cellranger binary must be installed separately"
echo "Download from: https://support.10xgenomics.com/single-cell-gene-expression/software/downloads/latest"
EOF
    chmod +x /usr/local/bin/cellranger-info
    
    # For this container, we assume cellranger is available via:
    # 1. Host installation (via --bind)
    # 2. Binary download and installation
    # 3. Custom prebuilt container
    
    # ==========================================
    # Upgrade Python packages
    # ==========================================
    echo "Installing Python packages..."
    
    pip install --upgrade pip setuptools wheel
    
    # Core single-cell analysis
    pip install --no-cache-dir \
        'scanpy==1.10.0' \
        'anndata>=0.10.0' \
        'pandas>=2.0' \
        'numpy>=1.24' \
        'scipy>=1.10'
    
    # GPU-accelerated analysis (rapids-singlecell)
    pip install --no-cache-dir \
        'rapids-singlecell>=0.12.0' \
        'cuml-cu12>=25.12' \
        'cugraph-service-client' \
        'cugraph'
    
    # Batch integration
    pip install --no-cache-dir \
        'harmonypy>=0.2.0'
    
    # VDJ/immune analysis
    pip install --no-cache-dir \
        'scirpy>=0.13.0' \
        'pandas>=1.3' \
        'numpy>=1.20' \
        'numba' \
        'scikit-learn'
    
    # Utilities
    pip install --no-cache-dir \
        'click' \
        'pyyaml' \
        'tqdm' \
        'matplotlib' \
        'seaborn'
    
    # ==========================================
    # Install R and additional packages (optional)
    # ==========================================
    echo "Installing R for optional Seurat support..."
    
    apt-key adv --keyserver keyserver.ubuntu.com --recv-keys E298A3A825C0D65DFD57CBB651716619E084DAB9
    echo "deb https://cloud.r-project.org/bin/linux/ubuntu jammy-cran40/" | tee /etc/apt/sources.list.d/r-project.list
    apt-get update
    apt-get install -y r-base r-base-dev
    
    # R packages (minimal set for optional use)
    R --vanilla --slave << 'EOF'
options(repos = c(CRAN = "https://cloud.r-project.org"))
packages <- c("devtools", "ggplot2", "dplyr", "Matrix", "igraph")
for (pkg in packages) {
    tryCatch(install.packages(pkg, quiet = TRUE), error = function(e) {
        cat("Warning: Could not install", pkg, "\n")
    })
}
EOF
    
    # ==========================================
    # Environment verification
    # ==========================================
    echo "Verifying installation..."
    
    python3 -c "import scanpy; print(f'✓ Scanpy {scanpy.__version__}')"
    python3 -c "import rapids_singlecell; print('✓ rapids-singlecell installed')"
    python3 -c "import harmonypy; print(f'✓ harmonypy {harmonypy.__version__}')"
    python3 -c "import scirpy; print(f'✓ scirpy {scirpy.__version__}')"
    python3 -c "import cuml; print('✓ cuML GPU acceleration available')"
    
    # Verify CUDA
    python3 -c "
import torch
print(f'✓ PyTorch CUDA available: {torch.cuda.is_available()}')
if torch.cuda.is_available():
    print(f'  GPU: {torch.cuda.get_device_name(0)}')
    print(f'  CUDA Version: {torch.version.cuda}')
"
    
    # ==========================================
    # Cleanup
    # ==========================================
    apt-get clean
    rm -rf /var/lib/apt/lists/*
    pip cache purge
    
    echo "✓ Container build complete"

%runscript
    exec python3 "$@"

%startscript
    exec python3 "$@"
