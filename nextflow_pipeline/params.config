// params.config
// User-facing parameters for B-cell atlas pipeline

params {
    // Input files
    sample_sheet = null  // CSV with sample metadata: sample_id, batch_id, gex_fastq_*, vdj_fastq_*, etc.
    metadata_sheet = null  // Optional: Additional metadata to inject into .obs
    
    // Reference paths (flexible for desktop vs HPC)
    ref_dir = "/home/Apps/genomes/cellranger"  // Base reference directory
    genome = "GRCh38"  // Human genome version
    
    // Auto-construct reference paths
    gex_ref = "${params.ref_dir}/refdata-gex-${params.genome}-2024-A"
    vdj_ref = "${params.ref_dir}/refdata-cellranger-vdj-${params.genome}-alts-ensembl-7.1.0"
    atac_ref = "${params.ref_dir}/refdata-cellranger-arc-${params.genome}-2024-A"
    
    // Feature references (HTO, ADT, etc.)
    feature_ref_dir = "${params.ref_dir}/../features"
    hto_feature_ref = "${params.feature_ref_dir}/HTOB_feature_ref.csv"
    asap_feature_ref = "${params.feature_ref_dir}/TSC_feature_ref.csv"
    
    // Output directory
    outdir = "./results"
    
    // Container configuration
    container_default = "${params.singularity_cache_dir}/analysis-gpu-latest.sif"
    container_cellranger = "${params.singularity_cache_dir}/rapids-cellranger-latest.sif"
    singularity_cache_dir = "${System.getProperty('user.home')}/.singularity/cache"
    
    // Processing parameters
    
    // Cellranger multi
    cellranger_localcores = 16
    cellranger_localmem = 64
    create_bam = true
    
    // CellBender QC
    cellbender_enabled = true
    cellbender_cuda = true
    cellbender_epochs_min = 50
    cellbender_epochs_max = 150
    cellbender_learning_rate = 0.001
    cellbender_memory_per_cell_gb = 0.00001  // Auto-scale: total_mem = cell_count * this value, min 4GB
    
    // Doublet detection (scDblFinder)
    scdblfinder_threshold = 0.5  // Doublet classification threshold
    scdblfinder_min_library_size = 500  // Min UMI count per cell
    
    // Secondary analysis
    n_hvg = 2000  // Number of highly variable genes
    n_pcs = 50    // Number of principal components
    
    // Harmony batch integration (post-QC aggregation)
    harmony_enabled = true
    harmony_npcs = 50  // Number of PCs to use for Harmony integration
    harmony_theta = 2.0  // Theta parameter for Harmony
    harmony_gpu = true  // Use PyTorch GPU backend if available
    
    // rapids-singlecell clustering
    umap_neighbors = 15
    leiden_resolution = 1.0
    leiden_use_weights = true
    
    // HCA metadata compliance
    hca_compliance_enabled = true
    organism = "Homo sapiens"  // Default organism
    organ = "blood"  // Default organ/tissue
    
    // VDJ analysis
    include_vdj = null  // Auto-detect from sample sheet if null; override with true/false
    vdj_min_umi = 3  // Minimum UMI count for valid VDJ
    vdj_min_cells = 1  // Minimum cells for clonotype
    
    // GPU device allocation
    gpu_strategy = "auto"  // Options: 'auto' (dynamic detection), 'manual' (specify device), 'pool' (use available pool)
    gpu_devices_available = [0]  // Default GPU devices (override per system)
    gpu_queue = "gpu"  // Queue name for GPU jobs (HPC)
    cluster_gpu_options = ""  // Cluster-specific GPU options (e.g., "--gres=gpu:1")
    
    // HPC configuration
    hpc_queue = "compute"  // Default queue for CPU jobs
    hpc_cluster_options = ""  // Cluster-specific options
    
    // Execution control
    max_parallel_batches = 4  // Maximum number of batches to process in parallel
    save_intermediate = true  // Save post-QC, post-harmony checkpoints
    cleanup_intermediate = false  // Delete intermediate cellranger outputs after aggregation
    
    // Runtime diagnostics
    debug = false
    trace_enabled = true
    
    help = false
}

// Display help message
if (params.help) {
    println """
    ╔══════════════════════════════════════════════════════════════════════════════╗
    ║          B-Cell Atlas Nextflow Pipeline (DSL2)                               ║
    ║   GPU-accelerated secondary analysis for 1M-cell V(D)J datasets              ║
    ╚══════════════════════════════════════════════════════════════════════════════╝
    
    USAGE:
        nextflow run main.nf --sample_sheet samples.csv --ref_dir /path/to/refs
    
    REQUIRED PARAMETERS:
        --sample_sheet [file]      CSV file with sample metadata and FASTQ paths
        --ref_dir [path]           Directory containing Cell Ranger references (default: ${params.ref_dir})
    
    OPTIONAL PARAMETERS:
        --genome [str]             Genome version for references (default: ${params.genome})
        --outdir [path]            Output directory (default: ${params.outdir})
        
        // GPU & Resource Control
        --gpu_strategy [str]       GPU allocation strategy: auto|manual|pool (default: ${params.gpu_strategy})
        --gpu_devices_available    Comma-separated GPU IDs (default: ${params.gpu_devices_available})
        
        // Processing Options
        --cellbender_enabled       Enable CellBender ambient RNA removal (default: true)
        --cellbender_epochs_max    Max epochs for CellBender (default: ${params.cellbender_epochs_max})
        --harmony_npcs             PCs for Harmony integration (default: ${params.harmony_npcs})
        --leiden_resolution        Resolution for Leiden clustering (default: ${params.leiden_resolution})
        --n_hvg                    Number of HVGs (default: ${params.n_hvg})
        
        // VDJ Analysis
        --include_vdj [bool]       Include VDJ clonotype analysis (default: auto-detect)
        
        // HCA Metadata
        --organism [str]           Organism name (default: ${params.organism})
        --organ [str]              Organ/tissue (default: ${params.organ})
    
    PROFILES:
        -profile local             Desktop/laptop execution (default)
        -profile slurm             SLURM HPC cluster
        -profile sge               Sun Grid Engine HPC cluster
    
    EXAMPLES:
        # Single batch on desktop
        nextflow run main.nf -profile local \\
            --sample_sheet test_data/sample_sheet.csv \\
            --ref_dir /home/Apps/genomes/cellranger
        
        # Multi-batch on HPC cluster
        nextflow run main.nf -profile slurm \\
            --sample_sheet samples_all.csv \\
            --harmony_npcs 50 \\
            --leiden_resolution 1.2
    
    """
    exit 0
}

// Validate required parameters
if (!params.sample_sheet) {
    error "Error: --sample_sheet is required. Use --help for usage information."
}

if (!file(params.sample_sheet).exists()) {
    error "Error: Sample sheet not found: ${params.sample_sheet}"
}

if (!file(params.gex_ref).exists()) {
    error "Error: GEX reference not found: ${params.gex_ref}"
}
