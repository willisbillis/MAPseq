// nextflow.config
// Runtime configuration for B-cell atlas Nextflow DSL2 pipeline

manifest {
    name = 'B-Cell Atlas Nextflow Pipeline'
    description = 'GPU-accelerated single-cell genomics pipeline for million-cell V(D)J datasets'
    author = 'MAPseq Team'
    version = '1.0.0'
    nextflowVersion = '>=24.04.0'
}

// Include parameter configuration
includeConfig "${baseDir}/params.config"

// Process configuration with resource labels
process {
    container = { task.ext.container ?: params.container_default }
    containerOptions = { task.ext.container ? '--bind /tmp:/tmp' : '' }
    
    // Default resources
    cpus = { task.attempt == 1 ? 4 : 8 }
    memory = { task.attempt == 1 ? 16.GB : 32.GB }
    time = { task.attempt == 1 ? 12.h : 24.h }
    
    // Process labels for different task types
    withLabel: 'cpu_small' {
        cpus = 2
        memory = 8.GB
        time = 4.h
    }
    
    withLabel: 'cpu_medium' {
        cpus = 8
        memory = 32.GB
        time = 12.h
    }
    
    withLabel: 'cpu_large' {
        cpus = 16
        memory = 64.GB
        time = 24.h
    }
    
    // GPU processes with dynamic device allocation
    withLabel: 'gpu_small' {
        cpus = 4
        memory = 16.GB
        time = 6.h
        containerOptions = '--nv --gpus=${task.gpu}'
        queue = params.gpu_queue
        clusterOptions = params.cluster_gpu_options
    }
    
    withLabel: 'gpu_medium' {
        cpus = 8
        memory = 32.GB
        time = 12.h
        containerOptions = '--nv --gpus=${task.gpu}'
        queue = params.gpu_queue
        clusterOptions = params.cluster_gpu_options
    }
    
    withLabel: 'gpu_large' {
        cpus = 16
        memory = 64.GB
        time = 24.h
        containerOptions = '--nv --gpus=${task.gpu}'
        queue = params.gpu_queue
        clusterOptions = params.cluster_gpu_options
    }
}

// Container engine configuration
docker {
    enabled = false
}

singularity {
    enabled = true
    autoMounts = true
    cacheDir = params.singularity_cache_dir
}

// Profiles for different execution environments
profiles {
    // Local development (desktop)
    local {
        process {
            executor = 'local'
            maxForks = 2  // Limit parallelism on desktop
            cpus = { task.attempt == 1 ? 2 : 4 }
            memory = { task.attempt == 1 ? 8.GB : 16.GB }
            
            withLabel: 'gpu_.*' {
                // Desktop: try to use GPU if available, fallback to CPU
                containerOptions = '--nv --gpus=0 2>/dev/null || echo "GPU not available"'
            }
        }
    }
    
    // HPC with SLURM scheduler
    slurm {
        process {
            executor = 'slurm'
            queue = params.hpc_queue
            clusterOptions = params.hpc_cluster_options
            pollInterval = '30sec'
            queueStatInterval = '1min'
            submitRateLimit = '10sec'
        }
    }
    
    // HPC with SGE scheduler
    sge {
        process {
            executor = 'sge'
            queue = params.hpc_queue
            penv = 'smp'
            pollInterval = '30sec'
            queueStatInterval = '1min'
        }
    }
}

// Tracing and reporting
trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
    fields = 'task_id,name,status,exit,realtime,cpus,memory,container'
}

report {
    enabled = true
    file = "${params.outdir}/report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
}

dag {
    enabled = true
    file = "${params.outdir}/dag.svg"
}

// Error handling and retry logic
process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 2
}

// Cleanup on error/success
cleanup = true
